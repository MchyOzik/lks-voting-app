{
    "containerDefinitions": [
        {
            "name": "lks-vote-container",
            "image": "IMAGE_URI",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "name": "lks-vote-container-80-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [
                {
                    "sourceVolume": "vote-volume",
                    "containerPath": "/data",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "REDIS_HOST",
                    "valueFrom": "/lks/redis-host"
                }
            ],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/lks-td-vote",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "lks-td-vote",
    "taskRoleArn": "arn:aws:iam::214365501455:role/LabRole",
    "executionRoleArn": "arn:aws:iam::214365501455:role/LabRole",
    "networkMode": "awsvpc",
    "volumes": [
        {
            "name": "vote-volume",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-0e5f48b9208b438a1",
                "rootDirectory": "/",
                "transitEncryption": "ENABLED",
                "authorizationConfig": {
                    "accessPointId": "fsap-0a5886cadfde60217",
                    "iam": "ENABLED"
                }
            }
        }
    ],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072",
    "enableFaultInjection": false
}